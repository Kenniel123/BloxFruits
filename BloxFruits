repeat task.wait() until game:IsLoaded()
repeat task.wait() until game.Players.LocalPlayer

-- Team selection logic here
local playerGui = game.Players.LocalPlayer:WaitForChild("PlayerGui")
local maxWaitTime = 10
local waitStartTime = tick()

while tick() - waitStartTime < maxWaitTime do
    local chooseTeam = playerGui:FindFirstChild("Main (minimal)") and playerGui["Main (minimal)"]:FindFirstChild("ChooseTeam")
    if chooseTeam and chooseTeam.Visible == true then
        game:GetService("ReplicatedStorage").Remotes.CommF_:InvokeServer("SetTeam", "Pirates")
        task.wait(2)
        break
    end
    task.wait(0.1)
end

-- Then load the main script
loadstring(game:HttpGet("https://vss.pandadevelopment.net/virtual/file/e3130e2ebbb94977"))()
